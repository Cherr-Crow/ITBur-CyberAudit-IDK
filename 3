        # Пытаемся найти шрифт с поддержкой кириллицы
        font_registered = False

        # Список возможных путей к шрифтам
        font_paths = [
            '/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf',
            '/usr/share/fonts/TTF/DejaVuSans.ttf',
            '/usr/share/fonts/dejavu/DejaVuSans.ttf',
            '/usr/share/fonts/truetype/liberation/LiberationSans-Regular.ttf',
            '/usr/share/fonts/liberation/LiberationSans-Regular.ttf',
            'C:\\Windows\\Fonts\\arial.ttf',
            '/usr/share/fonts/truetype/freefont/FreeSans.ttf',
        ]

        # Пробуем зарегистрировать шрифт
        for font_path in font_paths:
            if os.path.exists(font_path):
                try:
                    pdfmetrics.registerFont(TTFont('CyrillicFont', font_path))
                    font_registered = True
                    print(f"{Colors.GOOD}✓ Шрифт загружен: {font_path}{Colors.RESET}")
                    break
                except:
                    continue

        # Если шрифт не найден, используем стандартный (но кириллица не будет работать)
