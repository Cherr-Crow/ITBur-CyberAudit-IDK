def check_system():
    print_section("ПРОВЕРКА ОКРУЖЕНИЯ", "🖥️")

    os_name = f"{platform.system()} {platform.release()}"
    if platform.system() == 'Linux':
        print_status('good', f'ОС: {os_name}')
        stats.add('system', 'good', f'ОС: {os_name}',
                 simple_msg='Операционная система: Linux')
    else:
        print_status('critical', f'ОС: {os_name} — только для Linux!')
        stats.add('system', 'critical', f'Неподдерживаемая ОС',
                 simple_msg='Эта программа работает только на Linux')
        return False

    if os.geteuid() == 0:
        print_status('good', 'Права root: подтверждены ✓')
        stats.add('system', 'good', 'Запуск с root',
                 simple_msg='Программа запущена с правами администратора')
    else:
        print_status('warning', 'Запущено БЕЗ прав root')
        stats.add('system', 'warning', 'Нет root-прав',
                 simple_msg='Программа запущена без прав администратора',
                 simple_fix='Запустите с командой: sudo python3 audit.py')
    return True

