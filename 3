            try:
                mode = oct(os.stat(filepath).st_mode)[-3:]
                if mode == target_mode:
                    status, status_txt = 'good', f'OK ({mode})'
                else:
                    is_crit = any(x in filepath for x in ['shadow', 'sudoers'])
                    status = 'critical' if is_crit else 'warning'
                    status_txt = f'УЯЗВИМО ({mode})'

                color = Colors.DANGER if status == 'critical' else Colors.WARNING if status == 'warning' else Colors.GOOD
                print(f"  {color}{filepath:<35} | {target_mode:<10} | {mode:<12} | {status_txt:<15}{Colors.RESET}")

                simple_msgs = {
                    '/etc/passwd': 'Файл с пользователями',
                    '/etc/shadow': 'Файл с паролями',
                    '/etc/group': 'Файл с группами',
                    '/etc/sudoers': 'Настройки администратора',
                    '/etc/ssh/sshd_config': 'Настройки подключения',
                    '/etc/crontab': 'Расписание задач'
                }
                simple_msg = simple_msgs.get(filepath, filepath)

                stats.add('files', status, f'{filepath}: {mode}',
                         simple_msg=f'Права на {simple_msg}: {mode} (нужно {target_mode})' if status != 'good' else f'Права на {simple_msg} в порядке',
                         fix='chmod ' + target_mode + ' ' + filepath if status != 'good' else None,
                         simple_fix=f'Выполните: sudo chmod {target_mode} {filepath}' if status != 'good' else None)
            except PermissionError:
                print(f"  {Colors.WARNING}{filepath:<35} | {target_mode:<10} | {'НЕТ ДОСТУПА':<12} | {'ПРОВЕРЬТЕ':<15}{Colors.RESET}")
                stats.add('files', 'warning', f'Нет доступа к {filepath}',
                         simple_msg=f'Нет доступа к файлу {filepath}',
                         simple_fix='Запустите программу с sudo')
        else:
            print(f"  {Colors.DIM}{filepath:<35} | {target_mode:<10} | {'—':<12} | {'НЕ НАЙДЕН':<15}{Colors.RESET}")
            stats.add('files', 'info', f'Файл не найден: {filepath}',
                     simple_msg=f'Файл {filepath} не найден')
    print()

def network_audit():
    print_section("СЕТЕВОЙ АУДИТ", "🌐")
    print(f"  {Colors.BOLD}{'Порт':<8} | {'Сервис':<12} | {'Статус':<10} | {'Риск':<10} | {'Рекомендация'}{Colors.RESET}")
    print(f"  {Colors.DIM}{'─' * 80}{Colors.RESET}")

    simple_names = {
        'FTP': 'Передача файлов',
        'SSH': 'Удалённое подключение',
        'Telnet': 'Старое подключение',
        'HTTP': 'Сайт без защиты',
        'HTTPS': 'Сайт с защитой',
        'MySQL': 'База данных',
        'Redis': 'База данных Redis'
    }

    for port, (name, risk_level, description) in CONFIG['suspicious_ports'].items():
        try:
            s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            s.settimeout(0.2)
            result = s.connect_ex(('127.0.0.1', port))
            s.close()

            if result == 0:
                status = 'ОТКРЫТ'
                if risk_level == 'critical':
                    color, rec, st = Colors.DANGER, 'Закрыть!', 'critical'
                elif risk_level == 'warning':
                    color, rec, st = Colors.WARNING, 'Проверить', 'warning'
                else:
                    color, rec, st = Colors.GOOD, 'OK', 'good'
            else:
                status, color, rec, st = 'ЗАКРЫТ', Colors.DIM, '—', 'good'

            print(f"  {color}{port:<8} | {name:<12} | {status:<10} | {risk_level.upper():<10} | {rec}{Colors.RESET}")

            simple_name = simple_names.get(name, name)
            stats.add('network', st, f'Порт {port}/{name}: {status.lower()}',
                     simple_msg=f'Порт {port} ({simple_name}): {status.lower()}' if status == 'ОТКРЫТ' else f'Порт {port} ({simple_name}) закрыт',
                     details=description,
                     fix=rec if rec != '—' else None,
                     simple_fix=f'Закройте порт {port} в настройках фаервола' if rec == 'Закрыть!' else None)
        except:
            print(f"  {Colors.WARNING}{port:<8} | {name:<12} | {'ОШИБКА':<10} | {'—':<10} | {'—'}{Colors.RESET}")
            stats.add('network', 'warning', f'Ошибка проверки порта {port}',
                     simple_msg=f'Не удалось проверить порт {port}')

    print(f"\n  {Colors.BOLD}Брандмауэр:{Colors.RESET}")
    fw_found = False
    for cmd, name in [(['iptables', '-L', '-n'], 'iptables'), (['ufw', 'status'], 'UFW')]:
        try:
            result = subprocess.run(cmd, capture_output=True, text=True, timeout=5)
            if result.returncode == 0 and ('ACCEPT' in result.stdout or 'Status: active' in result.stdout):
                print(f"  {Colors.GOOD}✓{Colors.RESET} {name}: активен")
                stats.add('network', 'good', f'{name} активен',
                         simple_msg='Брандмауэр включён')
                fw_found = True
                break
        except:
            pass
    if not fw_found:
        print(f"  {Colors.DANGER}✗{Colors.RESET} Брандмауэр не обнаружен")
        stats.add('network', 'critical', 'Нет фаервола',
                 simple_msg='Брандмауэр не включён',
                 simple_fix='Выполните: sudo apt install ufw && sudo ufw enable')
    print()

def user_audit():
    print_section("ПОЛЬЗОВАТЕЛИ", "👥")

    zero_uid = []
    with open('/etc/passwd') as f:
        for line in f:
            parts = line.strip().split(':')
            if len(parts) >= 3 and parts[2] == '0' and parts[0] != 'root':
                zero_uid.append(parts[0])

    if zero_uid:
        print(f"  {Colors.DANGER}✗ Пользователи с UID 0: {', '.join(zero_uid)}{Colors.RESET}")
        stats.add('users', 'critical', f'UID 0: {", ".join(zero_uid)}',
                 simple_msg=f'Есть пользователи с правами админа: {", ".join(zero_uid)}',
                 simple_fix='Удалите лишних пользователей')
    else:
        print_status('good', 'Только root имеет UID 0')
        stats.add('users', 'good', 'UID 0 только у root',
                 simple_msg='Только главный администратор имеет полные права')

    try:
        result = subprocess.run(['awk', '-F:', '($2 == "" || $2 == "!") {print $1}', '/etc/shadow'],
                               capture_output=True, text=True, timeout=5)
        no_pass = [u for u in result.stdout.strip().split('\n') if u and u not in ['nobody', 'nologin']]
        if no_pass:
            print(f"  {Colors.DANGER}✗ Без пароля: {', '.join(no_pass)}{Colors.RESET}")
            stats.add('users', 'critical', f'Без пароля: {", ".join(no_pass)}',
                     simple_msg=f'У пользователей нет пароля: {", ".join(no_pass)}',
                     simple_fix='Установите пароль: sudo passwd <имя>')
        else:
            print_status('good', 'Все пользователи имеют пароли')
            stats.add('users', 'good', 'Пароли у всех пользователей',
                     simple_msg='У всех пользователей есть пароли')
    except:
        stats.add('users', 'warning', 'Не удалось проверить пароли',
                 simple_msg='Не удалось проверить наличие паролей')
    print()

def ssh_audit():
    print_section("НАСТРОЙКИ SSH", "🔑")
    ssh_cfg = '/etc/ssh/sshd_config'
    if not os.path.exists(ssh_cfg):
        print_status('warning', 'Настройки SSH не найдены')
        stats.add('services', 'warning', 'Нет sshd_config',
                 simple_msg='Настройки SSH не найдены')
        return

    try:
        with open(ssh_cfg) as f:
            content = f.read().lower()

        checks = [
            ('permitrootlogin', 'no', 'critical', 'Вход root'),
            ('passwordauthentication', 'no', 'warning', 'Вход по паролю'),
            ('permitemptypasswords', 'no', 'critical', 'Пустые пароли'),
        ]

        for param, expected, risk, desc in checks:
            pattern = rf'^\s*{param}\s+{expected}'
            if re.search(pattern, content, re.MULTILINE | re.IGNORECASE):
                print_status('good', f'{param}: {expected} ✓')
                stats.add('services', 'good', f'SSH {param}={expected}',
                         simple_msg=f'{param}: настроено правильно')
            else:
                color = Colors.DANGER if risk == 'critical' else Colors.WARNING
                print(f"  {color}✗{Colors.RESET} {param}: не задано")
                stats.add('services', risk, f'SSH {param}',
                         simple_msg=f'{param}: требует настройки',
                         simple_fix=f'Добавьте в /etc/ssh/sshd_config: {param} {expected}')
    except Exception as e:
        print_status('warning', f'Ошибка: {e}')
    print()

def package_audit():
    print_section("ПРОГРАММЫ", "📦")
    print(f"  {Colors.BOLD}{'Программа':<25} | {'Статус':<15}{Colors.RESET}")
    print(f"  {Colors.DIM}{'─' * 80}{Colors.RESET}")

    installed = set()
    for cmd in [['dpkg', '--get-selections'], ['rpm', '-qa']]:
        try:
            result = subprocess.run(cmd, capture_output=True, text=True, timeout=10)
            for line in result.stdout.split('\n'):
                if line.strip():
                    installed.add(line.split()[0].lower())
        except:
            pass

    for pkg in CONFIG['suspicious_packages']:
        found = any(pkg in inst for inst in installed)
        if found:
            print(f"  {Colors.WARNING}{pkg:<25} | {'УСТАНОВЛЕН':<15}{Colors.RESET}")
            stats.add('services', 'warning', f'Пакет {pkg} установлен',
                     simple_msg=f'Установлена программа: {pkg}',
                     simple_fix=f'Удалите: sudo apt remove {pkg}')
        else:
            print(f"  {Colors.DIM}{pkg:<25} | {'НЕ НАЙДЕН':<15}{Colors.RESET}")
            stats.add('services', 'good', f'Пакет {pkg} не установлен',
                     simple_msg=f'Программа {pkg} не установлена')
    print()

